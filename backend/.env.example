# Which LLM backend to use: "anthropic" (cloud) or "ollama" (local).
PROVIDER=anthropic

# How many files to analyse concurrently. Cloud (Anthropic) benefits from a
# higher number; for a single local Ollama model the requests are serialized on
# the GPU, so keep this modest (raising it won't speed things up locally, and a
# large model can OOM). To parallelise locally, raise Ollama's own
# OLLAMA_NUM_PARALLEL (server-side) — VRAM permitting.
# SCAN_CONCURRENCY=5

# --- PROVIDER=anthropic (cloud Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# --- PROVIDER=ollama (local, free) ---
# Requires Ollama running locally (`ollama serve`) with the model pulled
# (`ollama pull qwen2.5-coder:14b`). No API key needed.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:14b
# OLLAMA_NUM_CTX=16384
